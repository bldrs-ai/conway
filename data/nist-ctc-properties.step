ISO-10303-21;
HEADER;
FILE_DESCRIPTION(('NIST CTC general_property chain reduction'),'2;1');
FILE_NAME('nist-ctc-properties.step','2026-06-29T00:00:00',(''),(''),'','','');
FILE_SCHEMA(('AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF { 1 0 10303 442 1 1 4 }'));
ENDSEC;
DATA;
#4375=APPLICATION_PROTOCOL_DEFINITION('international standard',
  'ap242_managed_model_based_3d_engineering_mim_lf',2011,#4376);
#4376=APPLICATION_CONTEXT('managed model based 3d engineering');

/* the single part */
#4373=PRODUCT_CONTEXT('',#4376,'mechanical');
#4374=PRODUCT('NIST Test Case 1','NIST Complex Test Case 1','',(#4373));
#4369=PRODUCT_DEFINITION_FORMATION_WITH_SPECIFIED_SOURCE('','',#4374,.NOT_KNOWN.);
#4367=PRODUCT_DEFINITION_CONTEXT('part definition',#4376,'design');
#4368=PRODUCT_DEFINITION('design','',#4369,#4367);
#4269=PRODUCT_DEFINITION_SHAPE('','NIST Complex Test Case 1 Shape',#4368);

/* a length unit, referenced (lazily) by the measure properties */
#16=( LENGTH_UNIT() NAMED_UNIT(*) SI_UNIT(.MILLI.,.METRE.) );

/* attribute properties: general_property -> association -> property_definition */
#4296=GENERAL_PROPERTY('','Modeled By',$);
#4297=GENERAL_PROPERTY('','CAGE Code',$);
#4298=GENERAL_PROPERTY('','Company',$);
#4291=GENERAL_PROPERTY_ASSOCIATION('',$,#4296,#4331);
#4292=GENERAL_PROPERTY_ASSOCIATION('',$,#4297,#4332);
#4293=GENERAL_PROPERTY_ASSOCIATION('',$,#4298,#4333);
#4331=PROPERTY_DEFINITION('Modeled By',$,#4368);
#4332=PROPERTY_DEFINITION('CAGE Code',$,#4368);
#4333=PROPERTY_DEFINITION('Company',$,#4368);
#4301=PROPERTY_DEFINITION_REPRESENTATION(#4331,#4316);
#4302=PROPERTY_DEFINITION_REPRESENTATION(#4332,#4317);
#4303=PROPERTY_DEFINITION_REPRESENTATION(#4333,#4318);
#4316=REPRESENTATION('',(#4346),#4351);
#4317=REPRESENTATION('',(#4347),#4351);
#4318=REPRESENTATION('',(#4348),#4351);
#4346=DESCRIPTIVE_REPRESENTATION_ITEM('','Engineer');
#4347=DESCRIPTIVE_REPRESENTATION_ITEM('','64JW1');
#4348=DESCRIPTIVE_REPRESENTATION_ITEM('','ACME');

/* geometric validation property: volume + wetted area (no general_property) */
#4335=PROPERTY_DEFINITION('geometric validation property',
  'volume of NIST Complex Test Case 1',#4269);
#4305=PROPERTY_DEFINITION_REPRESENTATION(#4335,#4320);
#4320=REPRESENTATION('',(#635,#636),#4351);
#635=MEASURE_REPRESENTATION_ITEM('volume measure',VOLUME_MEASURE(14644822.6361138),#16);
#636=MEASURE_REPRESENTATION_ITEM('wetted area measure',AREA_MEASURE(807080.802199914),#16);

#4351=( GEOMETRIC_REPRESENTATION_CONTEXT(3)
  GLOBAL_UNIT_ASSIGNED_CONTEXT((#16))
  REPRESENTATION_CONTEXT('Context','3D') );
ENDSEC;
END-ISO-10303-21;
