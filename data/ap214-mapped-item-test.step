ISO-10303-21;
HEADER;
FILE_DESCRIPTION ('AP214 mapped-item + CTO3D test fixture','2;1');
FILE_NAME('ap214-mapped-item-test','2026-01-01T00:00:00',('test'),('bldrs'),'','','');
FILE_SCHEMA(('AUTOMOTIVE_DESIGN { 1 0 10303 214 1 1 1 1 }'));
ENDSEC;
DATA;
#1 = APPLICATION_PROTOCOL_DEFINITION('international standard','automotive_design',2010,#2);
#2 = APPLICATION_CONTEXT('mechanical design');
#10 = CARTESIAN_POINT('',(0.,0.,0.));
#11 = CARTESIAN_POINT('',(10.,0.,0.));
#12 = CARTESIAN_POINT('',(100.,0.,0.));
#13 = CARTESIAN_POINT('',(50.,0.,0.));
#20 = DIRECTION('',(0.,0.,1.));
#21 = DIRECTION('',(1.,0.,0.));
#30 = AXIS2_PLACEMENT_3D('',#11,#20,#21);
#31 = AXIS2_PLACEMENT_3D('',#12,#20,#21);
#40 = SHAPE_REPRESENTATION('',(#30),#100);
#50 = REPRESENTATION_MAP(#30,#40);
#60 = MAPPED_ITEM('',#50,#31);
#70 = CARTESIAN_TRANSFORMATION_OPERATOR_3D('','',$,$,#13,2.,$);
#100 = ( GEOMETRIC_REPRESENTATION_CONTEXT(3) GLOBAL_UNCERTAINTY_ASSIGNED_CONTEXT((#104)) GLOBAL_UNIT_ASSIGNED_CONTEXT((#101,#102,#103)) REPRESENTATION_CONTEXT('Context','3D') );
#101 = ( LENGTH_UNIT() NAMED_UNIT(*) SI_UNIT(.MILLI.,.METRE.) );
#102 = ( NAMED_UNIT(*) PLANE_ANGLE_UNIT() SI_UNIT($,.RADIAN.) );
#103 = ( NAMED_UNIT(*) SI_UNIT($,.STERADIAN.) SOLID_ANGLE_UNIT() );
#104 = UNCERTAINTY_MEASURE_WITH_UNIT(LENGTH_MEASURE(1.E-07),#101,'','');
ENDSEC;
END-ISO-10303-21;
